{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": false,            
    "noUnusedLocals": false,    
    "noUnusedParameters": false, 
    "noImplicitAny": false,  
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
